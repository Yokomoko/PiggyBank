<ui:FluentWindow x:Class="PiggyBank.App.Analytics.PastMonthWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 AutomationProperties.AutomationId="PastMonthWindow"
                 Title="Past month — PiggyBank"
                 Width="1080" Height="720"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="Past month — PiggyBank" />

        <Grid Grid.Row="1" Margin="24,8,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- compact header + metric pills -->
                <RowDefinition Height="*" />     <!-- two-column body -->
            </Grid.RowDefinitions>

            <!-- Header strip -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <ui:TextBlock FontTypography="Title">
                        <Run Text="Past month · " /><Run Text="{Binding StatusLabel, Mode=OneWay}" />
                    </ui:TextBlock>
                    <ui:TextBlock FontTypography="Caption" Margin="0,2,0,0"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  Text="{Binding PeriodLabel}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Padding="10,6" Margin="0,0,8,0" CornerRadius="6"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <StackPanel>
                            <ui:TextBlock FontSize="10" FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          Text="SALARY" />
                            <ui:TextBlock FontTypography="BodyStrong"
                                          Text="{Binding MonthlySalary, StringFormat='£#\,##0.00'}" />
                        </StackPanel>
                    </Border>
                    <Border Padding="10,6" Margin="0,0,8,0" CornerRadius="6"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <StackPanel>
                            <ui:TextBlock FontSize="10" FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          Text="{Binding SavingsHeadline}" />
                            <ui:TextBlock FontTypography="BodyStrong"
                                          Text="{Binding ProjectedSavings, StringFormat='£#\,##0.00'}" />
                        </StackPanel>
                    </Border>
                    <Border Padding="10,6" CornerRadius="6"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <StackPanel>
                            <ui:TextBlock FontSize="10" FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          Text="RUNNING BALANCE" />
                            <ui:TextBlock FontTypography="BodyStrong"
                                          Text="{Binding GrandTotal, StringFormat='£#\,##0.00'}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Two-column body -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Outgoings -->
                <ui:Card Grid.Column="0" Margin="0,0,6,0" Padding="0"
                         VerticalContentAlignment="Stretch">
                    <Grid VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <ui:TextBlock Grid.Row="0" FontTypography="Subtitle"
                                      Margin="14,12,14,8" Text="Outgoings" />
                        <Border Grid.Row="1" Padding="14,6,14,6"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock FontSize="10" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="NAME" />
                                <ui:TextBlock Grid.Column="1" FontSize="10" FontWeight="SemiBold"
                                              TextAlignment="Right" Margin="0,0,12,0"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="AMOUNT" />
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Outgoings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="14,6,14,6"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                           TextAlignment="Right" Margin="0,0,12,0"
                                                           Text="{Binding AmountDisplay}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </ui:Card>

                <!-- Ledger + category rollup -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" MinHeight="120" />
                    </Grid.RowDefinitions>

                    <ui:Card Grid.Row="0" Margin="6,0,0,6" Padding="0"
                             VerticalContentAlignment="Stretch">
                        <Grid VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <ui:TextBlock Grid.Row="0" FontTypography="Subtitle"
                                          Margin="14,12,14,8" Text="Ledger" />
                            <Border Grid.Row="1" Padding="14,6,14,6"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock FontSize="10" FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="DATE" />
                                    <ui:TextBlock Grid.Column="1" FontSize="10" FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="PAYEE" />
                                    <ui:TextBlock Grid.Column="2" FontSize="10" FontWeight="SemiBold"
                                                  TextAlignment="Right" Margin="0,0,12,0"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="AMOUNT" />
                                    <ui:TextBlock Grid.Column="3" FontSize="10" FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="CATEGORY" />
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Transactions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14,6,14,6"
                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="180" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center"
                                                               Text="{Binding Date, StringFormat='dd MMM yyyy'}" />
                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                               Text="{Binding Payee}" />
                                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                               TextAlignment="Right" Margin="0,0,12,0"
                                                               Text="{Binding AmountDisplay}" />
                                                    <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Text="{Binding Category}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </ui:Card>

                    <!-- Category rollup -->
                    <ui:Card Grid.Row="1" Margin="6,6,0,0" Padding="14,12">
                        <StackPanel>
                            <ui:TextBlock FontTypography="Subtitle" Text="Spend by category" />
                            <ItemsControl ItemsSource="{Binding CategoryRollups}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" />
                                            <TextBlock Grid.Column="1" Text="{Binding TotalDisplay}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ui:Card>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
