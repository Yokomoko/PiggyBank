<ui:FluentWindow x:Class="PiggyBank.App.Pockets.ArchivePocketTransferWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 AutomationProperties.AutomationId="ArchivePocketTransferWindow"
                 Title="Archive pocket — PiggyBank"
                 Width="520" Height="500"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Archive pocket — PiggyBank" />

        <Grid Grid.Row="1" Margin="32,8,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ui:TextBlock Grid.Row="0" FontTypography="TitleLarge"
                          Text="{Binding Headline}" />
            <ui:TextBlock Grid.Row="1" Margin="0,4,0,16"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                          TextWrapping="Wrap"
                          Text="This pocket still has a balance — pick what to do with it before archiving." />

            <!-- Balance summary -->
            <ui:Card Grid.Row="2" Padding="12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  Text="Balance to move" />
                    <ui:TextBlock Grid.Column="1" FontTypography="TitleLarge"
                                  Text="{Binding BalanceDisplay}" />
                </Grid>
            </ui:Card>

            <!-- Transfer path: only when there's at least one other active pocket -->
            <StackPanel Grid.Row="3"
                        Visibility="{Binding HasTransferTargets, Converter={StaticResource BoolToVisibility}}">
                <ui:TextBlock FontTypography="Subtitle" Text="Transfer to another pocket" />
                <ui:TextBlock Margin="0,2,0,8"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              TextWrapping="Wrap"
                              Text="Moves the full balance over, then archives this pocket. Recorded as a deposit so the history stays intact." />
                <ComboBox AutomationProperties.AutomationId="ArchiveTransferTargetCombo"
                          ItemsSource="{Binding TransferTargets}"
                          SelectedItem="{Binding SelectedTarget, Mode=TwoWay}"
                          DisplayMemberPath="Name" />
                <ui:Button Margin="0,12,0,0"
                           HorizontalAlignment="Left"
                           Appearance="Primary"
                           AutomationProperties.AutomationId="ConfirmTransferAndArchiveButton"
                           Content="Transfer and archive"
                           Command="{Binding TransferAndArchiveCommand}" />
            </StackPanel>

            <!-- "No other pockets" hint, only when there's nowhere to transfer to -->
            <Border Grid.Row="3" Margin="0,0,0,4" Padding="10,6" CornerRadius="6"
                    Background="{DynamicResource SystemAccentColorLightBrush}"
                    Visibility="{Binding HasTransferTargets, Converter={StaticResource InverseBoolToVisibility}}">
                <ui:TextBlock TextWrapping="Wrap"
                              Text="{Binding NoTargetsMessage}" />
            </Border>

            <Separator Grid.Row="4" Margin="0,16,0,12" />

            <ui:TextBlock Grid.Row="5" FontTypography="Subtitle" Text="Or write it off" />
            <ui:TextBlock Grid.Row="6" Margin="0,2,0,8"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                          TextWrapping="Wrap"
                          Text="Discards the balance entirely (with a confirmation step). Use this when the pocket no longer reflects real money — e.g. provider closed it." />

            <ui:Button Grid.Row="7" VerticalAlignment="Top"
                       HorizontalAlignment="Left"
                       Appearance="Caution"
                       AutomationProperties.AutomationId="WriteOffAndArchiveButton"
                       Content="Write off and archive"
                       Command="{Binding WriteOffAndArchiveCommand}" />

            <!-- Error surface -->
            <Border Grid.Row="8" Margin="0,12,0,0" Padding="10,6" CornerRadius="6"
                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                <ui:TextBlock TextWrapping="Wrap" Text="{Binding ErrorMessage}" />
            </Border>

            <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <ui:Button AutomationProperties.AutomationId="CancelArchiveButton"
                           Content="Cancel"
                           Click="OnCancelClick"
                           IsCancel="True" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
