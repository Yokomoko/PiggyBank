<UserControl x:Class="PiggyBank.App.Pockets.PocketsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <ui:TextBlock FontTypography="TitleLarge" Text="Savings pockets" />
                <ui:TextBlock FontTypography="Body"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              Text="Virtual jars for your savings. Record a deposit to auto-distribute by your chosen percentages." />
            </StackPanel>
            <ui:Button Grid.Column="1" Appearance="Primary"
                       AutomationProperties.AutomationId="RecordDepositButton"
                       Content="Record deposit"
                       Command="{Binding RecordDepositCommand}"
                       Visibility="{Binding HasPockets, Converter={StaticResource BoolToVisibility}}" />
        </Grid>

        <!-- Summary cards -->
        <Grid Grid.Row="1" Margin="0,0,0,12"
              Visibility="{Binding HasPockets, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ui:Card Grid.Column="0" Padding="16" Margin="0,0,8,0">
                <StackPanel>
                    <ui:TextBlock FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  Text="TOTAL BALANCE" />
                    <ui:TextBlock FontTypography="TitleLarge"
                                  Text="{Binding TotalBalance, StringFormat='£#\,##0.00'}" />
                </StackPanel>
            </ui:Card>
            <ui:Card Grid.Column="1" Padding="16" Margin="4,0,4,0">
                <StackPanel>
                    <ui:TextBlock FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  Text="PROJECTED ANNUAL INTEREST" />
                    <ui:TextBlock FontTypography="TitleLarge"
                                  Text="{Binding ProjectedAnnualInterest, StringFormat='£#\,##0.00'}" />
                </StackPanel>
            </ui:Card>
            <ui:Card Grid.Column="2" Padding="16" Margin="8,0,0,0">
                <StackPanel>
                    <ui:TextBlock FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  Text="AUTO-SAVE SUM" />
                    <ui:TextBlock FontTypography="TitleLarge"
                                  Text="{Binding AutoSaveSum, StringFormat='{}{0:0.#}%'}" />
                </StackPanel>
            </ui:Card>
        </Grid>

        <!-- Auto-save warning -->
        <Border Grid.Row="2" Margin="0,0,0,12" Padding="12,8" CornerRadius="6"
                Background="{DynamicResource SystemAccentColorLightBrush}"
                Visibility="{Binding AutoSaveWarn, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Info24" Margin="0,0,8,0" FontSize="14"
                               VerticalAlignment="Center" />
                <ui:TextBlock VerticalAlignment="Center" Text="{Binding AutoSaveWarning}" />
            </StackPanel>
        </Border>

        <!-- Empty state -->
        <ui:Card Grid.Row="3" Padding="40"
                 VerticalAlignment="Center" HorizontalAlignment="Center"
                 Visibility="{Binding HasPockets, Converter={StaticResource InverseBoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" MinWidth="420">
                <ui:TextBlock FontTypography="Title" HorizontalAlignment="Center"
                              Text="No pockets yet" />
                <ui:TextBlock Margin="0,8,0,16" MaxWidth="460" TextAlignment="Center"
                              TextWrapping="Wrap"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              Text="Add your first savings pocket below — you can rename, add, and archive at any time." />

                <!-- Inline add-pocket form (column captions above keep each field labelled) -->
                <StackPanel Margin="0,8,0,0">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock Grid.Column="0" FontTypography="Caption"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="NAME" />
                        <ui:TextBlock Grid.Column="1" FontTypography="Caption" Margin="6,0,0,0"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="BALANCE £" />
                        <ui:TextBlock Grid.Column="2" FontTypography="Caption" Margin="6,0,0,0"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="AUTOSAVE %" />
                        <ui:TextBlock Grid.Column="3" FontTypography="Caption" Margin="6,0,0,0"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="GOAL £" />
                        <ui:TextBlock Grid.Column="4" FontTypography="Caption" Margin="6,0,0,0"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="APR %" />
                        <ui:TextBlock Grid.Column="5" FontTypography="Caption" Margin="6,0,0,0"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="TARGET" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    AutomationProperties.AutomationId="NewPocketNameBox"
                                    PlaceholderText="e.g. Holiday fund"
                                    Text="{Binding NewPocketName, UpdateSourceTrigger=PropertyChanged}" />
                        <ui:NumberBox Grid.Column="1" Margin="6,0,0,0"
                                      AutomationProperties.AutomationId="NewPocketBalanceBox"
                                      SpinButtonPlacementMode="Hidden"
                                      Value="{Binding NewPocketCurrentBalance, Mode=TwoWay}" />
                        <ui:NumberBox Grid.Column="2" Margin="6,0,0,0"
                                      AutomationProperties.AutomationId="NewPocketAutoSaveBox"
                                      SpinButtonPlacementMode="Hidden"
                                      Value="{Binding NewPocketAutoSave, Mode=TwoWay}" />
                        <ui:NumberBox Grid.Column="3" Margin="6,0,0,0"
                                      AutomationProperties.AutomationId="NewPocketGoalBox"
                                      SpinButtonPlacementMode="Hidden"
                                      Value="{Binding NewPocketGoal, Mode=TwoWay}" />
                        <ui:NumberBox Grid.Column="4" Margin="6,0,0,0"
                                      AutomationProperties.AutomationId="NewPocketAprBox"
                                      SpinButtonPlacementMode="Hidden"
                                      Value="{Binding NewPocketAnnualRatePercent, Mode=TwoWay}" />
                        <DatePicker Grid.Column="5" Margin="6,0,0,0"
                                    SelectedDate="{Binding NewPocketTargetDate, Converter={StaticResource DateOnlyToDateTime}, Mode=TwoWay}" />
                        <ui:Button Grid.Column="6" Margin="6,0,0,0" Appearance="Primary"
                                   AutomationProperties.AutomationId="AddPocketButton"
                                   Content="Add pocket"
                                   Command="{Binding AddPocketCommand}" />
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ui:Card>

        <!-- Pocket list -->
        <ui:Card Grid.Row="3" Padding="16"
                 VerticalAlignment="Stretch"
                 VerticalContentAlignment="Stretch"
                 HorizontalContentAlignment="Stretch"
                 Visibility="{Binding HasPockets, Converter={StaticResource BoolToVisibility}}">
            <Grid VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Column headers -->
                <Grid Grid.Row="0" Margin="12,0,12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="NAME" />
                    <ui:TextBlock Grid.Column="1" FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="BALANCE £" />
                    <ui:TextBlock Grid.Column="2" FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="AUTOSAVE %" />
                    <ui:TextBlock Grid.Column="3" FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="GOAL £" />
                    <ui:TextBlock Grid.Column="4" FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="APR %" />
                    <ui:TextBlock Grid.Column="5" FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="TARGET DATE" />
                    <ui:TextBlock Grid.Column="6" FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="" />
                    <ui:TextBlock Grid.Column="7" FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="" />
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Pockets}"
                                  AutomationProperties.AutomationId="PocketList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,4" Padding="12" CornerRadius="6"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <ui:TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,6,0"
                                                    Text="{Binding Name, UpdateSourceTrigger=LostFocus}" />
                                        <ui:NumberBox Grid.Row="0" Grid.Column="1" Margin="0,0,6,0"
                                                      SpinButtonPlacementMode="Hidden"
                                                      Value="{Binding CurrentBalance, Mode=TwoWay}" />
                                        <ui:NumberBox Grid.Row="0" Grid.Column="2" Margin="0,0,6,0"
                                                      SpinButtonPlacementMode="Hidden"
                                                      Value="{Binding AutoSavePercent, Mode=TwoWay}" />
                                        <ui:NumberBox Grid.Row="0" Grid.Column="3" Margin="0,0,6,0"
                                                      SpinButtonPlacementMode="Hidden"
                                                      Value="{Binding Goal, Mode=TwoWay}" />
                                        <ui:NumberBox Grid.Row="0" Grid.Column="4" Margin="0,0,6,0"
                                                      SpinButtonPlacementMode="Hidden"
                                                      Value="{Binding AnnualRatePercent, Mode=TwoWay}" />
                                        <DatePicker Grid.Row="0" Grid.Column="5" Margin="0,0,6,0"
                                                    SelectedDate="{Binding TargetDate, Converter={StaticResource DateOnlyToDateTime}, Mode=TwoWay}" />
                                        <ui:Button Grid.Row="0" Grid.Column="6" Appearance="Transparent"
                                                   ToolTip="Deposit directly into this pocket (bypasses autosave + goal guard)"
                                                   Command="{Binding DataContext.DepositToPocketCommand,
                                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}">
                                            <ui:SymbolIcon Symbol="Add24" FontSize="14" />
                                        </ui:Button>
                                        <ui:Button Grid.Row="0" Grid.Column="7" Appearance="Transparent"
                                                   ToolTip="Archive pocket"
                                                   Command="{Binding DataContext.ArchiveRowCommand,
                                                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}">
                                            <ui:SymbolIcon Symbol="Archive24" FontSize="14" />
                                        </ui:Button>

                                        <StackPanel Grid.Row="1" Grid.ColumnSpan="8" Margin="0,8,0,0"
                                                    Visibility="{Binding HasGoal, Converter={StaticResource BoolToVisibility}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ProgressBar Height="6"
                                                             Minimum="0" Maximum="100"
                                                             Value="{Binding GoalProgress, Mode=OneWay}" />
                                                <ui:TextBlock Grid.Column="1" Margin="8,0,0,0"
                                                              FontTypography="Caption"
                                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                              Text="{Binding ProgressDisplay}" />
                                            </Grid>
                                            <ui:TextBlock Margin="0,4,0,0"
                                                          FontTypography="Caption"
                                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                          Text="{Binding TargetProjection}"
                                                          Visibility="{Binding HasTarget, Converter={StaticResource BoolToVisibility}}" />
                                            <ui:TextBlock Margin="0,4,0,0"
                                                          FontTypography="Caption"
                                                          Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                                          Text="Goal reached — autosave paused; deposits flow to other pockets."
                                                          Visibility="{Binding IsGoalReached, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Inline add-pocket row (columns align with the list + header; label strip
                     above the fields makes each input self-describing regardless of state). -->
                <Border Grid.Row="2" Margin="0,12,0,0" Padding="12" CornerRadius="6"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <ui:TextBlock FontTypography="Caption" Margin="0,0,0,6"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="ADD POCKET" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Margin="0,0,6,0"
                                        AutomationProperties.AutomationId="NewPocketNameBox"
                                        PlaceholderText="Pocket name"
                                        Text="{Binding NewPocketName, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:NumberBox Grid.Column="1" Margin="0,0,6,0"
                                          AutomationProperties.AutomationId="NewPocketBalanceBox"
                                          SpinButtonPlacementMode="Hidden"
                                          PlaceholderText="Balance £"
                                          Value="{Binding NewPocketCurrentBalance, Mode=TwoWay}" />
                            <ui:NumberBox Grid.Column="2" Margin="0,0,6,0"
                                          AutomationProperties.AutomationId="NewPocketAutoSaveBox"
                                          SpinButtonPlacementMode="Hidden"
                                          PlaceholderText="AutoSave %"
                                          Value="{Binding NewPocketAutoSave, Mode=TwoWay}" />
                            <ui:NumberBox Grid.Column="3" Margin="0,0,6,0"
                                          AutomationProperties.AutomationId="NewPocketGoalBox"
                                          SpinButtonPlacementMode="Hidden"
                                          PlaceholderText="Goal £ (opt.)"
                                          Value="{Binding NewPocketGoal, Mode=TwoWay}" />
                            <ui:NumberBox Grid.Column="4" Margin="0,0,6,0"
                                          AutomationProperties.AutomationId="NewPocketAprBox"
                                          SpinButtonPlacementMode="Hidden"
                                          PlaceholderText="APR %"
                                          Value="{Binding NewPocketAnnualRatePercent, Mode=TwoWay}" />
                            <DatePicker Grid.Column="5" Margin="0,0,6,0"
                                        SelectedDate="{Binding NewPocketTargetDate, Converter={StaticResource DateOnlyToDateTime}, Mode=TwoWay}" />
                            <ui:Button Grid.Column="6" Appearance="Primary"
                                       AutomationProperties.AutomationId="AddPocketButton"
                                       Content="Add"
                                       Command="{Binding AddPocketCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>
