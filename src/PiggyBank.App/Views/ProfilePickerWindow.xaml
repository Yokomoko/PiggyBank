<ui:FluentWindow x:Class="PiggyBank.App.Views.ProfilePickerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:a="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 AutomationProperties.AutomationId="ProfilePickerWindow"
                 Title="Choose profile — PiggyBank"
                 Width="520" Height="480"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Choose profile — PiggyBank" />

        <Grid Grid.Row="1" Margin="32,8,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ui:TextBlock Grid.Row="0" FontTypography="TitleLarge" Text="PiggyBank" />
            <ui:TextBlock Grid.Row="1" FontTypography="Body" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                          Margin="0,4,0,16"
                          Text="Pick a profile, or create a new one." />

        <ListBox Grid.Row="2"
                 AutomationProperties.AutomationId="ProfileList"
                 ItemsSource="{Binding Profiles}"
                 SelectedItem="{Binding Selected, Mode=TwoWay}"
                 BorderThickness="0" Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="14" Height="14" CornerRadius="7"
                                Background="{Binding ColourHex, Converter={StaticResource HexToBrush}}"
                                VerticalAlignment="Center" />
                        <ui:TextBlock Grid.Column="1" Margin="10,0,0,0"
                                      FontTypography="BodyStrong"
                                      Text="{Binding DisplayName}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <ui:Button Content="Create new"
                           AutomationProperties.AutomationId="CreateProfileButton"
                           Appearance="Secondary"
                           Command="{Binding CreateProfileCommand}"
                           Margin="0,0,8,0" />
                <ui:Button Content="Open"
                           AutomationProperties.AutomationId="OpenProfileButton"
                           Appearance="Primary"
                           Command="{Binding OpenCommand}"
                           IsDefault="True" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
