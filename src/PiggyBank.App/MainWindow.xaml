<ui:FluentWindow x:Class="PiggyBank.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:dashboard="clr-namespace:PiggyBank.App.Dashboard"
                 AutomationProperties.AutomationId="MainWindow"
                 Title="PiggyBank"
                 Width="1280" Height="800"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ui:TitleBar is required when ExtendsContentIntoTitleBar=True so
             the window stays draggable. Header hosts the profile chip.
             Settings button is OUTSIDE the title bar because WPF-UI's
             TitleBar treats child controls as drag surface — clicks get
             swallowed into window-drag rather than firing the button. -->
        <ui:TitleBar Grid.Row="0" Title="PiggyBank">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="12,0,0,0"
                            VerticalAlignment="Center">
                    <Border Width="10" Height="10" CornerRadius="5"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Background="{Binding ProfileColour, Converter={StaticResource HexToBrush}}" />
                    <ui:TextBlock AutomationProperties.AutomationId="ProfileHeadingText"
                                  Text="{Binding ProfileHeading}"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="24,8,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <ui:Button Content="Current Month"
                               AutomationProperties.AutomationId="NavCurrentMonth"
                               Appearance="Transparent"
                               Margin="0,0,4,0"
                               Click="OnNavCurrentMonthClicked" />
                    <ui:Button Content="Analytics"
                               AutomationProperties.AutomationId="NavAnalytics"
                               Appearance="Transparent"
                               Margin="0,0,4,0"
                               Click="OnNavAnalyticsClicked" />
                    <ui:Button Content="Debts"
                               AutomationProperties.AutomationId="NavDebts"
                               Appearance="Transparent"
                               Margin="0,0,4,0"
                               Click="OnNavDebtsClicked" />
                    <ui:Button Content="Pockets"
                               AutomationProperties.AutomationId="NavPockets"
                               Appearance="Transparent"
                               Margin="0,0,4,0"
                               Click="OnNavPocketsClicked" />
                    <ui:Button Content="Joint"
                               AutomationProperties.AutomationId="NavJoint"
                               Appearance="Transparent"
                               Margin="0,0,4,0"
                               Click="OnNavJointClicked" />
                    <ui:Button Content="Side Income"
                               AutomationProperties.AutomationId="NavSideIncome"
                               Appearance="Transparent"
                               Click="OnNavSideIncomeClicked" />
                </StackPanel>

                <ui:Button Grid.Column="1" Appearance="Transparent"
                           AutomationProperties.AutomationId="SettingsButton"
                           ToolTip="Settings"
                           Click="OnSettingsClicked">
                    <ui:SymbolIcon Symbol="Settings24" />
                </ui:Button>
            </Grid>

            <ContentControl Grid.Row="1" x:Name="RootContent" />
        </Grid>
    </Grid>
</ui:FluentWindow>
