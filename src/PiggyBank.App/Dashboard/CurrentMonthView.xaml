<UserControl x:Class="PiggyBank.App.Dashboard.CurrentMonthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:PiggyBank.App.Dashboard">

    <UserControl.Resources>
        <!-- Column widths defined inline in each Grid (header + rows share identical
             literals). GridLength-in-Resources is unreliable in WPF because its string
             ctor doesn't get invoked for <GridLength>X</GridLength> element syntax —
             the resource resolves to the default zero-width, collapsing the header. -->

        <Style x:Key="GridHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="GridHeaderRight" TargetType="TextBlock" BasedOn="{StaticResource GridHeader}">
            <Setter Property="TextAlignment" Value="Right" />
            <!-- 12px right margin stops the right-aligned AMOUNT header from touching
                 the next column's left-aligned header (e.g. CATEGORY in the ledger). -->
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
        <Style x:Key="AmountCellText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,16,24,16">
        <Grid.RowDefinitions>
            <!-- 0: header (compact) with inline metrics pills -->
            <RowDefinition Height="Auto" />
            <!-- 1: rollover banner (collapses when not shown) -->
            <RowDefinition Height="Auto" />
            <!-- 2: main body — Outgoings | Ledger, fills all remaining space -->
            <RowDefinition Height="*" />
            <!-- 3: slim month-header strip (paydays, salary input, carryover, save/close) -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ========== Row 0: compact header with inline metric pills ========== -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <ui:TextBlock FontTypography="Title" Text="Current month" />
                <ui:TextBlock FontTypography="Caption" Margin="0,2,0,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              Text="{Binding PeriodLabel}" />
            </StackPanel>

            <!-- Inline metric pills (grow-right, so they don't shove the title) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        Visibility="{Binding NeedsMonthCreated, Converter={StaticResource InverseBoolToVisibility}}">
                <Border Padding="10,6" Margin="0,0,8,0" CornerRadius="6"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        ToolTip="Your monthly salary for this pay cycle. Click the eye icon on the right to mask it for shoulder-surf privacy.">
                    <StackPanel>
                        <ui:TextBlock FontSize="10" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="SALARY" />
                        <ui:TextBlock FontTypography="BodyStrong"
                                      AutomationProperties.AutomationId="SalaryDisplayText"
                                      Text="{Binding SalaryDisplay}" />
                    </StackPanel>
                </Border>
                <Border Padding="10,6" Margin="0,0,8,0" CornerRadius="6"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        ToolTip="Trend extrapolation: today's spend-per-day rate × days remaining, compared with your sustainable daily budget.&#10;&#10;Negative trend (shortfall) means at this pace you'll overspend the budget — even if Running balance still looks healthy. Positive trend (savings) means you're tracking under and the unspent amount is what you'd land with at next payday.&#10;&#10;Different from Running balance: that's actual cash left right now; this is the projection of what's coming.">
                    <StackPanel>
                        <ui:TextBlock FontSize="10" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="{Binding SavingsHeadline}" />
                        <StackPanel Orientation="Horizontal">
                            <ui:TextBlock FontTypography="BodyStrong"
                                          AutomationProperties.AutomationId="ProjectedSavingsText"
                                          Text="{Binding ProjectedSavings, StringFormat='£#\,##0.00'}" />
                            <ui:Button Margin="8,0,0,0" Padding="8,0"
                                       Appearance="Primary"
                                       Content="Record"
                                       AutomationProperties.AutomationId="RecordSavingsButton"
                                       Command="{Binding RecordSavingsCommand}"
                                       Visibility="{Binding IsSavingsPositive, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Padding="10,6" Margin="0,0,8,0" CornerRadius="6"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        ToolTip="Sustainable daily spend for the rest of the month. Stay under this number each day to land on-budget by next payday.&#10;&#10;Computed from Running balance ÷ days remaining, minus the per-day buffer set in Settings.">
                    <StackPanel>
                        <ui:TextBlock FontSize="10" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="HEADROOM TODAY" />
                        <ui:TextBlock FontTypography="BodyStrong"
                                      AutomationProperties.AutomationId="AllowedSpendPerDayText"
                                      Text="{Binding AllowedSpendPerDay, StringFormat='£#\,##0.00'}" />
                    </StackPanel>
                </Border>
                <Border Padding="10,6" CornerRadius="6"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        ToolTip="Cash actually left in this pay cycle right now.&#10;&#10;Salary + outgoings (signed) − spending so far + carried-over balance.&#10;&#10;If you stopped spending today, this is what you'd finish the cycle with. Compare with Projected savings/shortfall — that's the trend, this is the snapshot.">
                    <StackPanel>
                        <ui:TextBlock FontSize="10" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="RUNNING BALANCE" />
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Text="{Binding GrandTotal, StringFormat='£#\,##0.00'}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <ui:Button Grid.Column="3"
                       VerticalAlignment="Center"
                       AutomationProperties.AutomationId="ToggleWageButton"
                       Appearance="Secondary"
                       Command="{Binding ToggleWageCommand}"
                       Visibility="{Binding NeedsMonthCreated, Converter={StaticResource InverseBoolToVisibility}}">
                <ui:Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Eye24" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding SalaryToggleLabel}" />
                    </StackPanel>
                </ui:Button.Content>
            </ui:Button>
        </Grid>

        <!-- ========== Row 1: rollover banner ========== -->
        <Border Grid.Row="1" Margin="0,0,0,12"
                Padding="12,8" CornerRadius="6"
                Background="{DynamicResource SystemAccentColorLightBrush}"
                Visibility="{Binding RolloverBannerVisible, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <ui:TextBlock FontTypography="BodyStrong"
                                  Text="Prior month closing balance available" />
                    <TextBlock Margin="0,2,0,0">
                        <Run Text="Previous month closed with" />
                        <Run FontWeight="SemiBold"
                             Text="{Binding SuggestedRollover, StringFormat='£#\,##0.00', Mode=OneWay}" />
                        <Run Text="remaining. Apply as carry-over?" />
                    </TextBlock>
                </StackPanel>
                <ui:Button Grid.Column="1" Content="Apply"
                           Appearance="Primary" Margin="12,0,4,0"
                           Command="{Binding ApplyRolloverCommand}" />
                <ui:Button Grid.Column="2" Content="Later"
                           Appearance="Secondary"
                           Command="{Binding DismissRolloverBannerCommand}" />
            </Grid>
        </Border>

        <!-- ========== Empty state (only when NeedsMonthCreated) ========== -->
        <ui:Card Grid.Row="2"
                 Padding="40"
                 VerticalAlignment="Center" HorizontalAlignment="Center"
                 Visibility="{Binding NeedsMonthCreated, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center">
                <ui:TextBlock FontTypography="Title" HorizontalAlignment="Center" Text="No open month" />
                <ui:TextBlock FontTypography="Body" Margin="0,8,0,16" HorizontalAlignment="Center"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center"
                              Text="Start a new pay cycle to begin tracking. Your recurring outgoings are snapshotted into this month; editing them here doesn't rewrite history." />
                <ui:Button Content="Start this month"
                           AutomationProperties.AutomationId="StartMonthButton"
                           Appearance="Primary"
                           HorizontalAlignment="Center"
                           Command="{Binding CreateCurrentMonthCommand}" />
            </StackPanel>
        </ui:Card>

        <!-- ========== Row 2: main body — Outgoings | Ledger ========== -->
        <Grid Grid.Row="2"
              Visibility="{Binding NeedsMonthCreated, Converter={StaticResource InverseBoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="460" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== OUTGOINGS ===== -->
            <ui:Card Grid.Column="0" Margin="0,0,6,0" Padding="0"
                     VerticalAlignment="Stretch"
                     VerticalContentAlignment="Stretch"
                     HorizontalContentAlignment="Stretch">
                <Grid VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Card title -->
                    <ui:TextBlock Grid.Row="0" FontTypography="Subtitle"
                                  Margin="14,12,14,8" Text="Outgoings" />

                    <!-- Column headers (same ColumnDefinitions as each row below).
                         Right padding of 17px reserves the scrollbar width so the columns
                         stay aligned whether the scrollbar is visible or not. -->
                    <Border Grid.Row="1" Padding="14,6,31,6"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource GridHeader}" Text="NAME" />
                            <TextBlock Grid.Column="1" Style="{StaticResource GridHeader}" Text="ALLOC?" ToolTip="Allocation — ledger transactions drawdown from this budget" />
                            <TextBlock Grid.Column="2" Style="{StaticResource GridHeaderRight}" Text="AMOUNT" />
                            <TextBlock Grid.Column="3" Style="{StaticResource GridHeader}" Text="" />
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Visible">
                        <ItemsControl AutomationProperties.AutomationId="OutgoingsGrid"
                                      ItemsSource="{Binding Outgoings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14,6,14,6"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="36" />
                                                </Grid.ColumnDefinitions>
                                                <ui:TextBox Grid.Column="0" BorderThickness="0" Background="Transparent"
                                                            Padding="0" Margin="0"
                                                            VerticalContentAlignment="Center"
                                                            Text="{Binding Name, UpdateSourceTrigger=LostFocus}" />
                                                <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          IsChecked="{Binding IsAllocation, Mode=TwoWay}"
                                                          ToolTip="Set aside this amount — ledger items in the matching category draw down from it" />
                                                <ui:NumberBox Grid.Column="2"
                                                              BorderThickness="0" Background="Transparent"
                                                              Padding="0" Margin="0,0,12,0"
                                                              HorizontalContentAlignment="Right"
                                                              VerticalContentAlignment="Center"
                                                              SpinButtonPlacementMode="Hidden"
                                                              Value="{Binding Amount, Mode=TwoWay}"
                                                              GotKeyboardFocus="OnAmountBoxGotFocus"
                                                              TextChanged="OnRowAmountTextChanged" />
                                                <ui:Button Grid.Column="3" Appearance="Transparent" ToolTip="Delete"
                                                           Command="{Binding DataContext.DeleteOutgoingCommand,
                                                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           CommandParameter="{Binding}">
                                                    <ui:SymbolIcon Symbol="Delete24" FontSize="14" />
                                                </ui:Button>
                                            </Grid>
                                            <!-- Allocation progress strip: only shown when IsAllocation && has been used -->
                                            <Border Grid.Row="1" Margin="0,6,0,0"
                                                    Visibility="{Binding IsAllocation, Converter={StaticResource BoolToVisibility}}">
                                                <ui:TextBlock FontTypography="Caption"
                                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                              Text="{Binding AllocationSummary}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Add-outgoing row (same columns, plus Add button) -->
                    <Border Grid.Row="3" Padding="14,8,14,12"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Margin="0,0,6,0"
                                        AutomationProperties.AutomationId="AddOutgoingNameBox"
                                        PlaceholderText="Add outgoing (e.g. rent -900)"
                                        Text="{Binding NewOutgoingName, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Grid.Column="1" VerticalAlignment="Center" Margin="0,0,6,0"
                                      Content="Alloc"
                                      IsChecked="{Binding NewOutgoingIsAllocation, Mode=TwoWay}"
                                      ToolTip="Tag as allocation — ledger entries in this category draw down from the amount" />
                            <ui:NumberBox Grid.Column="2" Margin="0,0,6,0"
                                          x:Name="AddOutgoingAmountBox"
                                          AutomationProperties.AutomationId="AddOutgoingAmountBox"
                                          SpinButtonPlacementMode="Hidden"
                                          PlaceholderText="Amount"
                                          Value="{Binding NewOutgoingAmount, Mode=TwoWay}"
                                          TextChanged="OnAmountBoxTextChanged"
                                          GotKeyboardFocus="OnAmountBoxGotFocus" />
                            <ui:Button Grid.Column="3" Appearance="Primary"
                                       AutomationProperties.AutomationId="AddOutgoingButton"
                                       Content="Add" Command="{Binding AddOutgoingCommand}" />
                        </Grid>
                    </Border>
                </Grid>
            </ui:Card>

            <!-- ===== LEDGER ===== -->
            <ui:Card Grid.Column="1" Margin="6,0,0,0" Padding="0"
                     VerticalAlignment="Stretch"
                     VerticalContentAlignment="Stretch"
                     HorizontalContentAlignment="Stretch">
                <Grid VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Card title -->
                    <Grid Grid.Row="0" Margin="14,12,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock FontTypography="Subtitle" Text="Ledger" />
                        <ui:TextBlock Grid.Column="1" FontTypography="Caption"
                                      VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="Positive = income · negative = spend" />
                    </Grid>

                    <!-- Column headers. 17px right padding reserves scrollbar width. -->
                    <Border Grid.Row="1" Padding="14,6,31,6"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource GridHeader}" Text="DATE" />
                            <TextBlock Grid.Column="1" Style="{StaticResource GridHeader}" Text="PAYEE" />
                            <TextBlock Grid.Column="2" Style="{StaticResource GridHeaderRight}" Text="AMOUNT" />
                            <TextBlock Grid.Column="3" Style="{StaticResource GridHeader}" Text="CATEGORY (ALLOCATION)" />
                            <TextBlock Grid.Column="4" Style="{StaticResource GridHeader}" Text="" />
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Visible">
                        <ItemsControl AutomationProperties.AutomationId="LedgerGrid"
                                      ItemsSource="{Binding Transactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14,6,14,6"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="220" />
                                                <ColumnDefinition Width="36" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                       Text="{Binding Date, StringFormat='dd MMM yyyy'}" />
                                            <ui:TextBox Grid.Column="1" BorderThickness="0" Background="Transparent"
                                                        Padding="0" Margin="0"
                                                        VerticalContentAlignment="Center"
                                                        Text="{Binding Payee, UpdateSourceTrigger=LostFocus}" />
                                            <ui:NumberBox Grid.Column="2"
                                                          BorderThickness="0" Background="Transparent"
                                                          Padding="0" Margin="0,0,12,0"
                                                          HorizontalContentAlignment="Right"
                                                          VerticalContentAlignment="Center"
                                                          SpinButtonPlacementMode="Hidden"
                                                          Value="{Binding Amount, Mode=TwoWay}"
                                                          GotKeyboardFocus="OnAmountBoxGotFocus"
                                                          TextChanged="OnRowAmountTextChanged" />
                                            <ComboBox Grid.Column="3"
                                                      BorderThickness="0" Background="Transparent"
                                                      Padding="0" Margin="0"
                                                      HorizontalContentAlignment="Stretch"
                                                      VerticalContentAlignment="Center"
                                                      ItemsSource="{Binding DataContext.AvailableCategories,
                                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      DisplayMemberPath="Name"
                                                      SelectedValue="{Binding CategoryId, Mode=TwoWay}"
                                                      SelectedValuePath="Id"
                                                      IsEditable="True"
                                                      IsTextSearchEnabled="True"
                                                      TextSearch.TextPath="Name"
                                                      StaysOpenOnEdit="True" />
                                            <ui:Button Grid.Column="4" Appearance="Transparent" ToolTip="Delete"
                                                       Command="{Binding DataContext.DeleteSpendCommand,
                                                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding}">
                                                <ui:SymbolIcon Symbol="Delete24" FontSize="14" />
                                            </ui:Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Quick-add row -->
                    <Border Grid.Row="3" Padding="14,8,14,12"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <DatePicker Grid.Column="0" Margin="0,0,6,0"
                                        SelectedDate="{Binding NewSpendDate, Converter={StaticResource DateOnlyToDateTime}, Mode=TwoWay}" />
                            <ui:TextBox Grid.Column="1" Margin="0,0,6,0"
                                        AutomationProperties.AutomationId="QuickAddPayeeBox"
                                        PlaceholderText="Payee (Ctrl+N)"
                                        x:Name="QuickAddPayeeBox"
                                        Text="{Binding NewSpendPayee, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:NumberBox Grid.Column="2" Margin="0,0,6,0"
                                          x:Name="QuickAddAmountBox"
                                          AutomationProperties.AutomationId="QuickAddAmountBox"
                                          SpinButtonPlacementMode="Hidden"
                                          PlaceholderText="Amount"
                                          Value="{Binding NewSpendAmount, Mode=TwoWay}"
                                          TextChanged="OnAmountBoxTextChanged"
                                          GotKeyboardFocus="OnAmountBoxGotFocus" />
                            <ComboBox Grid.Column="3" Margin="0,0,6,0"
                                      AutomationProperties.AutomationId="QuickAddCategoryBox"
                                      ItemsSource="{Binding AvailableCategories}"
                                      SelectedItem="{Binding NewSpendCategory, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      TextSearch.TextPath="Name"
                                      StaysOpenOnEdit="True" />
                            <ui:Button Grid.Column="4" Appearance="Primary"
                                       AutomationProperties.AutomationId="AddSpendButton"
                                       Content="Add" Command="{Binding AddSpendCommand}" />
                        </Grid>
                    </Border>
                </Grid>
            </ui:Card>
        </Grid>

        <!-- ========== Row 3: slim month-header strip ========== -->
        <ui:Card Grid.Row="3" Margin="0,12,0,0" Padding="14,10"
                 Visibility="{Binding NeedsMonthCreated, Converter={StaticResource InverseBoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              Text="Salary £" />
                <Grid Grid.Column="1" Width="120" Margin="0,0,14,0">
                    <ui:NumberBox AutomationProperties.AutomationId="MonthlySalaryBox"
                                  SpinButtonPlacementMode="Hidden"
                                  Value="{Binding MonthlySalary, Mode=TwoWay, TargetNullValue={x:Null}}"
                                  Visibility="{Binding IsSalaryVisible, Converter={StaticResource BoolToVisibility}}" />
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Visibility="{Binding IsSalaryVisible, Converter={StaticResource InverseBoolToVisibility}}">
                        <ui:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="••••••" />
                    </Border>
                </Grid>

                <ui:TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              Text="Last payday" />
                <DatePicker Grid.Column="3" Width="170" Margin="0,0,14,0"
                            SelectedDate="{Binding LastPayday, Converter={StaticResource DateOnlyToDateTime}, Mode=TwoWay}" />

                <ui:TextBlock Grid.Column="4" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              Text="Next payday" />
                <DatePicker Grid.Column="5" Width="170" Margin="0,0,14,0"
                            SelectedDate="{Binding NextPayday, Converter={StaticResource DateOnlyToDateTime}, Mode=TwoWay}" />

                <ui:TextBlock Grid.Column="6" VerticalAlignment="Center" Margin="0,0,6,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              Text="Carry over £" />
                <ui:NumberBox Grid.Column="7" Width="110" Margin="0,0,14,0"
                              SpinButtonPlacementMode="Hidden"
                              Value="{Binding CarriedOverBalance, Mode=TwoWay}" />

                <Border Grid.Column="8" VerticalAlignment="Center" Margin="0,0,12,0"
                        Padding="8,4" CornerRadius="6"
                        Background="{DynamicResource AccentFillColorSelectedTextBackgroundBrush}"
                        AutomationProperties.AutomationId="MonthClosedBanner"
                        Visibility="{Binding IsClosed, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="LockClosed24" FontSize="14" Margin="0,0,6,0" />
                        <ui:TextBlock Text="Month closed — open next to continue."
                                      VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <ui:Button Grid.Column="9" Appearance="Secondary" Margin="0,0,6,0"
                           AutomationProperties.AutomationId="SaveHeaderButton"
                           Content="Save header"
                           Command="{Binding SaveMonthHeaderCommand}" />
                <ui:Button Grid.Column="10" Appearance="Danger"
                           AutomationProperties.AutomationId="CloseMonthButton"
                           Content="Close month"
                           Command="{Binding CloseMonthCommand}" />
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>
