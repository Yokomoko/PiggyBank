<ui:FluentWindow x:Class="PiggyBank.App.Settings.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 AutomationProperties.AutomationId="SettingsWindow"
                 Title="Settings — PiggyBank"
                 Width="520" Height="620"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Settings — PiggyBank" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,8,32,32">
                <ui:TextBlock FontTypography="TitleLarge" Text="Settings" />

            <!-- Theme -->
            <ui:Card Margin="0,16,0,0" Padding="16">
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong" Text="Appearance" />
                    <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  Margin="0,4,0,8"
                                  Text="Theme applies across profiles. Takes effect on save." />
                    <ComboBox AutomationProperties.AutomationId="ThemeComboBox"
                              ItemsSource="{Binding ThemeChoices}"
                              SelectedItem="{Binding Theme, Mode=TwoWay}" />
                </StackPanel>
            </ui:Card>

            <!-- This profile's settings -->
            <ui:Card Margin="0,12,0,0" Padding="16">
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong" Text="This profile" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                      Text="Daily food budget" Margin="0,0,0,6" />
                        <ui:NumberBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,6"
                                      SpinButtonPlacementMode="Hidden"
                                      Value="{Binding DailyFoodBudget, Mode=TwoWay}" />

                        <ui:TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                      Text="Buffer per day (£)" Margin="0,0,0,6" />
                        <ui:NumberBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6"
                                      SpinButtonPlacementMode="Hidden"
                                      Value="{Binding BufferPerDay, Mode=TwoWay}" />

                        <ui:TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                                      Text="Payday day of month" Margin="0,0,0,6" />
                        <ui:NumberBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,6"
                                      SpinButtonPlacementMode="Hidden"
                                      Minimum="1" Maximum="31"
                                      Value="{Binding PrimaryPaydayDayOfMonth, Mode=TwoWay}" />

                        <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                  Content="Bump earlier on weekends / UK bank holidays"
                                  IsChecked="{Binding AdjustPaydayForWeekendsAndBankHolidays, Mode=TwoWay}" />
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Categories -->
            <ui:Card Margin="0,12,0,0" Padding="16">
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong" Text="Categories" />
                    <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  Margin="0,4,0,8"
                                  Text="Per-profile. Add new categories used by transactions and outgoing rows. Archive hides a category from pickers without altering past tags." />

                    <ItemsControl ItemsSource="{Binding Categories}"
                                  AutomationProperties.AutomationId="CategoryList"
                                  Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,2"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Text="{Binding KindLabel}" />
                                        <ui:Button Grid.Column="2" Appearance="Transparent"
                                                   ToolTip="Archive category"
                                                   Command="{Binding DataContext.ArchiveCategoryCommand,
                                                                     RelativeSource={RelativeSource AncestorType=Window}}"
                                                   CommandParameter="{Binding}">
                                            <ui:SymbolIcon Symbol="Archive24" FontSize="14" />
                                        </ui:Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" Margin="0,0,6,0"
                                    AutomationProperties.AutomationId="NewCategoryNameBox"
                                    PlaceholderText="New category name"
                                    Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                        <ComboBox Grid.Column="1" Margin="0,0,6,0"
                                  AutomationProperties.AutomationId="NewCategoryKindCombo"
                                  ItemsSource="{Binding CategoryKindChoices}"
                                  SelectedItem="{Binding NewCategoryKind, Mode=TwoWay}"
                                  DisplayMemberPath="Label" />
                        <ui:Button Grid.Column="2" Appearance="Primary"
                                   AutomationProperties.AutomationId="AddCategoryButton"
                                   Content="Add"
                                   Command="{Binding AddCategoryCommand}" />
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- About -->
            <ui:Card Margin="0,12,0,0" Padding="16">
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong" Text="About" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ui:TextBlock Grid.Row="0" Grid.Column="0"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="Version" />
                        <ui:TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AppVersion}" />
                        <ui:TextBlock Grid.Row="1" Grid.Column="0" Margin="0,4,0,0"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="Data file" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"
                                 IsReadOnly="True"
                                 Text="{Binding DataPath, Mode=OneWay}"
                                 BorderThickness="0" Background="Transparent"
                                 TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </ui:Card>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <ui:TextBlock VerticalAlignment="Center"
                              Margin="0,0,12,0"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              Text="{Binding StatusMessage}" />
                <ui:Button Content="Save"
                           AutomationProperties.AutomationId="SettingsSaveButton"
                           Appearance="Primary"
                           Command="{Binding SaveCommand}" />
            </StackPanel>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
