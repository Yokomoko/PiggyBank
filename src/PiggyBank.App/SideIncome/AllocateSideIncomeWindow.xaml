<ui:FluentWindow x:Class="PiggyBank.App.SideIncome.AllocateSideIncomeWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 AutomationProperties.AutomationId="AllocateSideIncomeWindow"
                 Title="Allocate side income — PiggyBank"
                 Width="520" Height="440"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="Allocate side income — PiggyBank" />

        <Grid Grid.Row="1" Margin="32,8,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ui:TextBlock Grid.Row="0" FontTypography="Subtitle"
                          Text="{Binding Headline}" />
            <ui:TextBlock Grid.Row="1" Margin="0,2,0,16"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                          Text="{Binding RemainingDisplay}" />

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                <RadioButton GroupName="Target" Margin="0,0,16,0"
                             IsChecked="{Binding TargetPocket, Mode=TwoWay}"
                             Content="Deposit to pocket" />
                <RadioButton GroupName="Target"
                             IsChecked="{Binding TargetMainLedger, Mode=TwoWay}"
                             Content="Income on main ledger" />
            </StackPanel>

            <ComboBox Grid.Row="3" Margin="0,0,0,12"
                      ItemsSource="{Binding Pockets}"
                      SelectedItem="{Binding SelectedPocket, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      IsEnabled="{Binding TargetPocket}" />

            <ui:TextBlock Grid.Row="4" Margin="0,0,0,4"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Amount £" />
            <ui:NumberBox Grid.Row="5" Margin="0,0,0,12"
                          AutomationProperties.AutomationId="AllocateAmountBox"
                          SpinButtonPlacementMode="Hidden"
                          IsEnabled="{Binding AmountEditable}"
                          Value="{Binding Amount, Mode=TwoWay}" />

            <ui:TextBox Grid.Row="6" VerticalAlignment="Top"
                        PlaceholderText="Notes (optional)"
                        TextWrapping="Wrap"
                        Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />

            <Border Grid.Row="7" Margin="0,12,0,0" Padding="10,6" CornerRadius="6"
                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                <ui:TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
            </Border>

            <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <ui:Button Appearance="Primary"
                           AutomationProperties.AutomationId="ConfirmAllocateButton"
                           Content="Allocate"
                           Command="{Binding AllocateCommand}"
                           IsDefault="True" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
